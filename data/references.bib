  author = {Fauqué, Benoît and Chaney, Daniel A. and Bourges, Philippe and Raymond, Stéphane and Hiess, Arno and Steffens, Paul and Baptiste, Benoît and Paolasini, Luigi and Bosak, Alexeï and Behnia, Kamran and Tomioka, Yasuhide},
