@article{johnsonUltrafastXrayImaging2022,
  title = {Ultrafast {{X-ray}} Imaging of the Light-Induced Phase Transition in {{VO2}}},
  author = {Johnson, Allan S. and Perez-Salinas, Daniel and Siddiqui, Khalid M. and Kim, Sungwon and Choi, Sungwook and Volckaert, Klara and Majchrzak, Paulina E. and Ulstrup, Søren and Agarwal, Naman and Hallman, Kent and Haglund, Richard F. and Günther, Christian M. and Pfau, Bastian and Eisebitt, Stefan and Backes, Dirk and Maccherozzi, Francesco and Fitzpatrick, Ann and Dhesi, Sarnjeet S. and Gargiani, Pierluigi and Valvidares, Manuel and Artrith, Nongnuch and De Groot, Frank and Choi, Hyeongi and Jang, Dogeun and Katoch, Abhishek and Kwon, Soonnam and Park, Sang Han and Kim, Hyunjung and Wall, Simon E.},
