  author = {Romaguera, Arnau and Skoropata, Elizabeth and Yen, Yun and Liu, Biaolong and Nag, Abhishek and Huang, Shih-Wen and Leroy, Ludmila and Moos, Katja Sophia and Parusa, Gian and Zerdane, Serhane and Mandal, Ritwika and Mariette, Celine and Levantino, Matteo and Paris, Eugenio and Patthey, Luc and Pomjakushina, Ekaterina and Staub, Urs and Hatnean, Monica Ciomaga and Schueler, Michael and Razzoli, Elia and Ueda, Hiroki},
