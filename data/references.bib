  author = {Kneller, Omer and Mor, Chen and Klimkin, Nikolai D. and Yaffe, Noa and Krüger, Michael and Azoury, Doron and Uzan-Narovlansky, Ayelet J. and Federman, Yotam and Rajak, Debobrata and Bruner, Barry D. and Smirnova, Olga and Patchkovskii, Serguei and Mairesse, Yann and Ivanov, Misha and Dudovich, Nirit},
  date = {2025-02},
  journaltitle = {Nature Photonics},
  shortjournal = {Nat. Photon.},
  volume = {19},
