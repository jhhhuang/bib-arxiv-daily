@article{leendersCantedSpinOrder2024,
  title = {Canted Spin Order as a Platform for Ultrafast Conversion of Magnons},
  author = {Leenders, R. A. and Afanasiev, D. and Kimel, A. V. and Mikhaylovskiy, R. V.},
  date = {2024-05-29},
  journaltitle = {Nature},
