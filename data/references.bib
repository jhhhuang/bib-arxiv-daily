@online{
  title = {Room-Temperature High-Average-Power Strong-Field Terahertz Source Based on Industrial High-Repetition-Rate Femtosecond Laser},
  author = {Kong, Deyin and Su, Yichen and Song, Cheng and Wu, Xiaojun},
