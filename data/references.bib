  author = {Tyulnev, Igor and Jiménez-Galán, Álvaro and Poborska, Julita and Vamos, Lenard and Russell, Philip St. J. and Tani, Francesco and Smirnova, Olga and Ivanov, Misha and Silva, Rui E. F. and Biegert, Jens},
  date = {2024-04-25},
