  urldate = {2024-05-21},
  abstract = {We have shown that a strong polarization-shaped optical field, with symmetry matching the sub-lattice of the material, achieves valley polarization even in a bulk material with net-zero Berry curvature. We demonstrate optical control over the valley degree of freedom in bulk 2H-MoS2, a centrosymmetric material. The facts that no Berry curvature is required and the control is non-resonant with any material parameter make the demonstrated method universal and material-agnostic. Thus, the shown method should permit access to various enticing materials, for example, quantum solids with intrinsic entanglement, topological phases, or spin textures, which are difficult to produce with adequate size as monolayers. Further, the shown sub-optical-cycle control over the material’s electronic topology to induce valley polarization by transiently breaking time and space inversion symmetry through a simple phase rotation may offer an entirely new approach to ultrafast lightwave valleytronics for low-loss information processing in solids. Combining such capability with quantum materials with intrinsic correlations may further provide new avenues for strong-field quantum information processing and for producing massively entangled states on ultrafast timescales.},
  langid = {english},
  file = {C\:\\Users\\jhhuang\\Zotero\\storage\\BSCYDED9\\41586_2024_7156_MOESM1_ESM.pdf;C\:\\Users\\jhhuang\\Zotero\\storage\\RT6WTU87\\Tyulnev et al. - 2024 - Valleytronics in bulk MoS2 with a topologic optica.pdf}
