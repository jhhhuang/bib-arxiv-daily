@online{
  title = {Terahertz Nonlinear Response in Cuprate Superconductors and the {{Higgs}} Field in Doped {{Mott}} Insulators},
  author = {Li, Xiang and Weng, Zheng-Yu},
  date = {2025-09-10},
  eprint = {2509.08370},
