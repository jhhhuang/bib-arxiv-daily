@online{
  title = {Ferroelectric Quantum Criticality and Enhanced Superconductivity in Plastically Deformed Strontium Titanate},
  author = {Hameed, S. and Pelc, D. and Anderson, Z. W. and Klein, A. and Spieker, R. J. and Yue, L. and Das, B. and Ramberger, J. and Lukas, M. and Liu, Y. and Krogstad, M. J. and Osborn, R. and Li, Y. and Leighton, C. and Fernandes, R. M. and Greven, M.},
