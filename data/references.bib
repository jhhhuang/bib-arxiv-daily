  author = {Freudenstein, J. and Borsch, M. and Meierhofer, M. and Afanasiev, D. and Schmid, C. P. and Sandner, F. and Liebich, M. and Girnghuber, A. and Knorr, M. and Kira, M. and Huber, R.},
