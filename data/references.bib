@article{zhangTerahertzfielddrivenMagnonUpconversion2024,
  title = {Terahertz-Field-Driven Magnon Upconversion in an Antiferromagnet},
  author = {Zhang, Zhuquan and Gao, Frank Y. and Chien, Yu-Che and Liu, Zi-Jie and Curtis, Jonathan B. and Sung, Eric R. and Ma, Xiaoxuan and Ren, Wei and Cao, Shixun and Narang, Prineha and family=Hoegen, given=Alexander, prefix=von, useprefix=true and Baldini, Edoardo and Nelson, Keith A.},
  date = {2024-01-23},
  journaltitle = {Nature Physics},
