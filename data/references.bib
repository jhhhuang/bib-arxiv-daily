@article{rubanoTerahertzHyperRamanTimeDomain2019,
  title = {Terahertz {{Hyper-Raman Time-Domain Spectroscopy}}},
  author = {Rubano, Andrea and Mou, Sen and Marrucci, Lorenzo and Paparo, Domenico},
  date = {2019-06-19},
  journaltitle = {ACS Photonics},
