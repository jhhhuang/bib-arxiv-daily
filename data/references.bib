  author = {Yoshida, Shoji and Arashida, Yusuke and Hirori, Hideki and Tachizaki, Takehiro and Taninaka, Atsushi and Ueno, Hiroki and Takeuchi, Osamu and Shigekawa, Hidemi},
  date = {2021-01-20},
