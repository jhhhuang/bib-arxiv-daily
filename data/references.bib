  author = {Shi, Jiaojian and Heide, Christian and Xu, Haowei and Shen, Yuejun and Henstridge, Meredith and Sedwick, Isabel and Mangu, Anudeep and Peng, Xinyue and Zhang, Shangjie and Trigo, Mariano and Heinz, Tony F. and Li, Ju and Nelson, Keith A. and Baldini, Edoardo and Zhou, Jian and Ghimire, Shambhu and Reis, David A. and Lindenberg, Aaron M.},
