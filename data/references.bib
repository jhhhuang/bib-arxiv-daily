@online{
  title = {Pseudo-Chiral Phonon Splitting from Octupolar Magnetic Order},
  author = {Sutcliffe, Ruairidh and Hart, Kathleen and Chaudhary, Swati and Paramekanti, Arun},
  date = {2025-06-23},
  eprint = {2506.18978},
  eprinttype = {arXiv},
  eprintclass = {cond-mat},
  doi = {10.48550/arXiv.2506.18978},
  url = {http://arxiv.org/abs/2506.18978},
  urldate = {2025-07-20},
  abstract = {Motivated by the recent discovery of anomalously large magnetic response of chiral phonons in dipolar magnets, we explore an extension to study Einstein quantum phonon modes coupled to multipolar moments. We consider the case of non-Kramers \$\textbackslash Gamma\_3\$ doublets which encapsulate quadrupolar and Ising octupolar degrees of freedom, and which feature a symmetry-allowed linear coupling between local quadrupolar moments and Raman active \$E\_g\$ phonon modes \$(d\_\{x\textasciicircum 2-y\textasciicircum 2\},d\_\{3z\textasciicircum 2-r\textasciicircum 2\})\$. We show that either octupolar or quadrupolar ordering leads to degeneracy breaking of the \$E\_g\$ phonon doublet, with ferro-octupolar order favoring pseudo-chiral phonon eigenmodes with a detectable energy splitting. We describe this physics using a path integral approach in the limit where `fast' phonon modes sense the `slow' pseudospins as a static background which we average over using Monte Carlo simulations. We discuss implications for materials such as Ba\$\_2\$CaOsO\$\_6\$ and PrV\$\_2\$Al\$\_\{20\}\$ where Raman spectroscopy of phonons could be used as a potential probe of hidden octupolar order. Our work extends the important concept of chiral phonons to a large class of multipolar magnets.},
  langid = {english},
  pubstate = {prepublished},
  keywords = {Condensed Matter - Strongly Correlated Electrons},
  file = {C:\Users\jhhuang\Zotero\storage\NJ5KC7L4\Sutcliffe et al. - 2025 - Pseudo-chiral phonon splitting from octupolar magnetic order.pdf}
}

