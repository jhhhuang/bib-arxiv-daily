@online{
  title = {Photostriction-{{Driven Phase Transition}} in {{Layered Chiral NbOX}}\$\_2\$ {{Crystals}}: {{Electrical-Field-Controlled Enantiomer Selectivity}}},
  shorttitle = {Photostriction-{{Driven Phase Transition}} in {{Layered Chiral NbOX}}\$\_2\$ {{Crystals}}},
  author = {Cardenas-Gamboa, Jorge and Gutierrez-Amigo, Martin and Leonardo, Aritz and Fiete, Gregory A. and Mañes, Juan L. and family=Brink, given=Jeroen, prefix=van den, useprefix=false and Felser, Claudia and Vergniory, Maia G.},
