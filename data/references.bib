  author = {Seo, C. and Shen, L. and Petsch, A. N. and Wandel, S. and Esposito, V. and Koralek, J. D. and Dakovski, G. L. and Lin, M.-F. and Moeller, S. P. and Schlotter, W. F. and Reid, A. H. and Minitti, M. P. and Liang, R. and Bonn, D. and Hardy, W. and Damascelli, A. and Giannetti, C. and Neto, E. H. da Silva and Turner, J. J. and Boschini, F. and Coslovich, G.},
