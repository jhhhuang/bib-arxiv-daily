  author = {Zhou, Lingxiao and Liu, Bin and Liu, Yuze and Lu, Yang and Li, Qiuyang and Xie, Xin and Lydick, Nathanial and Hao, Ruofan and Liu, Chenxi and Watanabe, Kenji and Taniguchi, Takashi and Chou, Yu-Hsun and Forrest, Stephen R. and Deng, Hui},
