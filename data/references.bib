@article{
  title = {Build-up and Dephasing of {{Floquet}}–{{Bloch}} Bands on Subcycle Timescales},
  author = {Ito, S. and Schüler, M. and Meierhofer, M. and Schlauderer, S. and Freudenstein, J. and Reimann, J. and Afanasiev, D. and Kokh, K. A. and Tereshchenko, O. E. and Güdde, J. and Sentef, M. A. and Höfer, U. and Huber, R.},
  date = {2023-04},
