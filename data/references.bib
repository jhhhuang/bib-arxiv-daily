@online{park2DVanWaals2025,
  title = {{{2D}} van Der {{Waals}} Magnets: From Fundamental Physics to Applications},
  shorttitle = {{{2D}} van Der {{Waals}} Magnets},
  author = {Park, Je-Geun and Zhang, Kaixuan and Cheong, Hyeonsik and Kim, Jae Hoon and Belvin, Carina and Hsieh, David and Ning, Honglie and Gedik, Nuh},
