@article{
  title = {Dissipation-Induced Symmetry Breaking: {{Emphanitic}} Transitions in Lead- and Tin-Containing Chalcogenides and Halide Perovskites},
  shorttitle = {Dissipation-Induced Symmetry Breaking},
  author = {Mukhuti, Kingshuk and Sinha, Sudip and Sinha, Subhasis and Bansal, Bhavtosh},
  date = {2021-04-19},
  journaltitle = {Applied Physics Letters},
  volume = {118},
  number = {16},
  pages = {162111},
