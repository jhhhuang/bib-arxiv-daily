@online{perez-martinTerahertzCavityHybridization2026,
  title = {Terahertz Cavity Hybridization of Collective Proteins Vibrations},
  author = {Perez-Martin, Elsa and Bonnet, Laurent and Fang, Songlin and Bannink, Jelle and Vrouwe, Elwin and Bray, Cedric and Teppe, Frederic and Ruffenach, Sandra and Strupiechonski, Elodie and Zhang, Zhedong and Torres, Jeremie},
