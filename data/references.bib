@online{watanabeFerroaxialMagnetsTimereversaleven2026,
  title = {Ferroaxial Magnets: Time-Reversal-Even Mirror Symmetry Violation from Spin Order},
  shorttitle = {Ferroaxial Magnets},
  author = {Watanabe, Hikaru and Yu, Yue and Matsuda, Jin and Agterberg, Daniel F. and Arita, Ryotaro},
  date = {2026-03-12},
  eprint = {2603.12502},
  eprinttype = {arXiv},
