  doi = {10.48550/arXiv.2509.08068},
  url = {http://arxiv.org/abs/2509.08068},
  urldate = {2025-09-15},
  abstract = {The \$\textbackslash Gamma\$-point topology represents a significant segment in the family of topological insulators. Here we provide a comprehensive prediction of light-induced \$\textbackslash Gamma\$-point-based topological manipulation in trigonal bismuthene and its derivatives. Our findings unveil a two-stage process of topological phase transitions (TPT) as the laser intensity increases. Initially, a quantum-spin-Hall or metallic state transitions to a quantum-anomalous-Hall (QAH) state (\$C\$ = \$\textbackslash pm\$3), followed by another TPT that yields a compensated Chern-insulating state (\$C\$ = 0). The trigonal warping model accounts for these states, describing the \$C\_\{3z\}\$-rotational band-inversion process, which is determined by \$\textbackslash pm\$1 orders of replica bands. Notably, this high Chern-number QAH state persists over a broad range of laser parameters, maintaining functionality beyond room temperature as evidenced by the large global gaps (\$\textbackslash geq\$ 60 meV). Our work provides a comprehensive roadmap towards the designer \$\textbackslash Gamma\$-point topology under laser excitation, facilitating applications of artificial topological materials.},
  langid = {english},
  pubstate = {prepublished},
  keywords = {Condensed Matter - Materials Science,Condensed Matter - Mesoscale and Nanoscale Physics},
  file = {C:\Users\jhhuang\Zotero\storage\U6DAH7LM\Li et al. - 2025 - Laser-engineered $Γ$-point Topology in Trigonal Bismuthene.pdf}
