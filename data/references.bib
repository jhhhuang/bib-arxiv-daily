@article{
  title = {The Ferroelectric Photo Ground State of {{SrTiO}}{\textsubscript{3}} : {{Cavity}} Materials Engineering},
  shorttitle = {The Ferroelectric Photo Ground State of {{SrTiO}}{\textsubscript{3}}},
  author = {Latini, Simone and Shin, Dongbin and Sato, Shunsuke A. and Schäfer, Christian and De Giovannini, Umberto and Hübener, Hannes and Rubio, Angel},
