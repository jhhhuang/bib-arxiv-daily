@online{
  title = {Two-Dimensional Coherent Spectroscopy of {{CoNb}}\$\_2\${{O}}\$\_6\$},
  author = {Watanabe, Yoshito and Trebst, Simon and Hickey, Ciarán},
  date = {2025-12-18},
