@article{restelliUltrafastFormationJahn2026,
  title = {Ultrafast {{Formation}} of {{Jahn}}–{{Teller Polarons Revealed}} by {{State-Selective Excitation}} in {{Correlated Spinel Co}}{\textsubscript{3}} {{O}}{\textsubscript{4}}},
