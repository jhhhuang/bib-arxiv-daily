  author = {Kono, Junichiro and Kim, Dasom and Dasgupta, Sohail and Ma, Xiaoxuan and Park, J-M and Wei, Hao-Tian and Luo, Liang and Doumani, Jacques and Li, Xinwei and Yang, Wanting and Cheng, Di and Kim, Richard and Everitt, Henry and Kimura, Shojiro and Nojiri, Hiroyuki and Wang, Jigang and Cao, Shixun and Bamba, Motoaki and Hazzard, Kaden},
