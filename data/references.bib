  shorttitle = {Attosecond Dynamics through a {{Fano}} Resonance},
  author = {Gruson, V. and Barreau, L. and Jiménez-Galan, Á. and Risoud, F. and Caillat, J. and Maquet, A. and Carré, B. and Lepetit, F. and Hergott, J.-F. and Ruchon, T. and Argenti, L. and Taïeb, R. and Martín, F. and Salières, P.},
  date = {2016-11-11},
  journaltitle = {Science},
  shortjournal = {Science},
