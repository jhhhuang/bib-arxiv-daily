@article{
  title = {Two-Dimensional Infrared Spectroscopy of Vibrational Polaritons},
  author = {Xiang, Bo and Ribeiro, Raphael F. and Dunkelberger, Adam D. and Wang, Jiaxi and Li, Yingmin and Simpkins, Blake S. and Owrutsky, Jeffrey C. and Yuen-Zhou, Joel and Xiong, Wei},
