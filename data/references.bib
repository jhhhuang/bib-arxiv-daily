  author = {Wang, Jia and Cai, Wentao and Lu, Weifang and Lu, Shun and Kano, Emi and Agulto, Verdad C. and Sarkar, Biplab and Watanabe, Hirotaka and Ikarashi, Nobuyuki and Iwamoto, Toshiyuki and Nakajima, Makoto and Honda, Yoshio and Amano, Hiroshi},
